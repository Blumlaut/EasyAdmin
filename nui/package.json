{
  "name": "easyadmin-nui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --open ?dev",
    "build": "tsc && vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:css": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run lint:css && npm run typecheck && npm run test",
    "extract:i18n": "node ../tools/extract-i18n.mjs",
    "find:untranslated": "node ../tools/find-untranslated.mjs",
    "duplication": "jscpd src/"
  },
  "dependencies": {
    "@citizenfx/three": "^0.100.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.4.0",
    "easyadmin": "file:..",
    "lucide-react": "^1.24.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chart.js": "^4.0.1",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss": "^4.1.0",
    "globals": "^17.7.0",
    "jscpd": "^5.0.12",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
